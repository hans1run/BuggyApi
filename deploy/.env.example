# PostgreSQL
POSTGRES_USER=buggy
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Auth0
AUTH0_DOMAIN=hans1.eu.auth0.com
AUTH0_AUDIENCE=buggyapi
AUTH0_ALLOWED_USER_ID=auth0|your-user-id-here

# API Key (for external integrations)
BUGGY_API_KEY=CHANGE_ME_buggy_api_key

# MinIO (S3-compatible storage)
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key
